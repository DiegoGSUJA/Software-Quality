{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Active File (G++)",
            "command": "C:/mingw64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/Farmacia.cpp",
                "${workspaceFolder}/Laboratorio.cpp",
                "${workspaceFolder}/MediExpress.cpp",
                "${workspaceFolder}/PaMedicamento.cpp",
                "${workspaceFolder}/Stock.cpp",
                "-o",
                "${workspaceFolder}/main.exe",
                "-std=c++17",
                "-Wall",
                "-Wextra"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}